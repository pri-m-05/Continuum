{
  "manifest_version": 3,
  "name": "Continuum Doc Assistant",
  "version": "1.1.0",
  "description": "Capture workflow actions, screenshots, meeting audio, generate documentation, audit docs, and suggest automation.",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Continuum",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}