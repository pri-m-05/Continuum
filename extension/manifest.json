{
  "manifest_version": 3,
  "name": "Continuum Doc Assistant",
  "version": "1.2.0",
  "description": "Intent-first documentation capture with side panel workspace, screenshots, and meeting notes.",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "tabCapture",
    "offscreen",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://continuum-61io.onrender.com//*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Continuum",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}